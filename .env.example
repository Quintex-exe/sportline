# ── FOOTINT VALUE TRACKER API CREDENTIALS ─────────────────────────────────────
# Copy this file to .env and fill in your actual API keys
# DO NOT commit .env with real keys to version control

# TRANSFERMARKT API
# Get free key at: https://transfermarkt-api.vercel.app
TRANSFERMARKT_API_KEY=your_transfermarkt_key_here

# STATSBOMB API (Free tier available)
# Register at: https://www.statsbomb.com/open-data/
# Limited historical data available without authentication
STATSBOMB_API_KEY=your_statsbomb_key_here

# FOOTBALL-DATA.ORG
# Register at: https://www.football-data.org/client/register
# Free tier: 10 calls per minute, 100 per day
FOOTBALL_DATA_API_KEY=your_football_data_key_here

# SOFASCORE API
# No authentication required - uses public API
# Rate limit: ~120 requests per minute
SOFASCORE_USER_AGENT=Mozilla/5.0 (FOOTINT/1.0)

# ── OPTIONAL: Alternative data sources ─────────────────────────────────────────

# RAPID API (Aggregates multiple sports APIs)
RAPID_API_KEY=your_rapid_api_key_here
RAPID_API_HOST=api-football-v1.p.rapidapi.com

# OPENDATA.FOOTBALL (European football data)
OPENDATA_FOOTBALL_KEY=your_opendata_key_here

# ── FEATURE FLAGS ──────────────────────────────────────────────────────────────

# Enable real-time value tracking
ENABLE_VALUE_TRACKING=true

# Enable WebSocket live updates
ENABLE_WEBSOCKET=false

# Cache expiry time (milliseconds)
CACHE_EXPIRY_MS=300000

# API rate limit mode (strict/relaxed/disabled)
RATE_LIMIT_MODE=strict
