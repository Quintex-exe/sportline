# ── FOOTINT ENV CONFIGURATION ─────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control — it is in .gitignore

# ── RUNTIME ────────────────────────────────────────────────────────────────────
# Which server runs: "node" or "flask"
# On Render: set this to match your Render start command
SERVER_RUNTIME=node
PORT=3000

# ── FOOTBALL DATA API (recommended — free tier) ────────────────────────────────
# Register free at: https://www.football-data.org/client/register
# Free tier: 10 calls/min, 100/day — enough for dev
FOOTBALL_DATA_API_KEY=4a413130f4e443d4bb0db3a4a7fae612

# ── TRANSFERMARKT API ──────────────────────────────────────────────────────────
# Free community API: https://transfermarkt-api.vercel.app
# No key required — uses public scraping proxy
TRANSFERMARKT_API_KEY=your_transfermarkt_key_here

# ── STATSBOMB (open data — no auth needed for free tier) ──────────────────────
# Register at: https://www.statsbomb.com/open-data/
STATSBOMB_API_KEY=your_statsbomb_key_here

# ── RAPID API (optional — aggregates multiple APIs) ───────────────────────────
# Register at: https://rapidapi.com
RAPID_API_KEY=your_rapid_api_key_here
RAPID_API_HOST=api-football-v1.p.rapidapi.com

# ── SOFASCORE (no auth required) ──────────────────────────────────────────────
# Rate limit: ~120 req/min
SOFASCORE_USER_AGENT=Mozilla/5.0 (FOOTINT/1.0)

# ── FEATURE FLAGS ──────────────────────────────────────────────────────────────
# Enable real-time player value tracking
ENABLE_VALUE_TRACKING=true

# Enable WebSocket live updates — set true for real-time feed
ENABLE_WEBSOCKET=true

# Cache expiry in milliseconds (5 minutes default)
CACHE_EXPIRY_MS=300000

# API rate limit mode: strict / relaxed / disabled
RATE_LIMIT_MODE=strict
